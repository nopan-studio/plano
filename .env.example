# Plano Project Environment Configuration

# Database Driver: 'sqlite' (default) or 'postgresql'
DB_DRIVER=sqlite

# PostgreSQL specific settings (ignored for SQLite)
DB_USER=plano_user
DB_PASS=plano_pass
DB_HOST=db
DB_PORT=5432
DB_NAME=plano_db

# Optional: Full connection string (overrides individual variables above)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Other optional configurations
# SECRET_KEY=your-secret-key
