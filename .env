# Plano Project Environment Configuration

# Database Driver: 'sqlite' (default) or 'postgresql'
DB_DRIVER=postgresql

# PostgreSQL specific settings (ignored for SQLite)
DB_USER=plano_user
DB_PASS=plano_pass
# Set to 'db' only if running INSIDE a Docker container network.
# For local development on the host machine, use 'localhost'.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plano_db

# Optional: Full connection string (overrides individual variables above)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Other optional configurations
# SECRET_KEY=your-secret-key
